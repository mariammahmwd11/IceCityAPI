@model Business_Layer.DTO.OwnerVm
@{
    Layout = "_layout";
    ViewData["Title"] = "Owner Details";

    var zoneColors = new Dictionary<string, string> {
        {"North","#3b9eff"},{"South","#00c9a7"},{"East","#f5a623"},
        {"West","#e84444"},{"Central","#9b59b6"}
    };

    string initials = string.Join("", (Model?.FullName ?? "?").Split(' ')
        .Where(w => w.Length > 0).Take(2).Select(w => w[0].ToString().ToUpper()));
}


@section Styles {
    <style>
        .owner-profile-card {
            background: linear-gradient(135deg, var(--primary) 0%, #1e3d5e 100%);
            border-radius: var(--radius);
            padding: 28px;
            color: #fff;
            position: relative;
            overflow: hidden;
        }

            .owner-profile-card::after {
                content: '';
                position: absolute;
                right: -60px;
                top: -60px;
                width: 220px;
                height: 220px;
                border-radius: 50%;
                background: rgba(0,201,167,.1);
                pointer-events: none;
            }

        .owner-big-avatar {
            width: 70px;
            height: 70px;
            border-radius: 50%;
            background: rgba(255,255,255,.15);
            backdrop-filter: blur(4px);
            border: 3px solid rgba(255,255,255,.3);
            display: grid;
            place-items: center;
            font-size: 1.6rem;
            font-weight: 800;
            font-family: 'Syne', sans-serif;
            color: #fff;
            flex-shrink: 0;
        }

        .owner-info-label {
            font-size: .72rem;
            text-transform: uppercase;
            letter-spacing: .8px;
            opacity: .6;
            margin-bottom: 2px;
        }

        .owner-info-value {
            font-size: .92rem;
            font-weight: 600;
        }

        .info-chip {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 5px 12px;
            border-radius: 20px;
            font-size: .8rem;
            font-weight: 600;
            background: rgba(255,255,255,.12);
            color: #fff;
        }
    </style>
}

<!-- Breadcrumb -->
<nav style="margin-bottom:18px" aria-label="breadcrumb">
    <ol class="breadcrumb" style="font-size:.82rem;background:none;padding:0;margin:0">
        <li class="breadcrumb-item"><a href="/Mayor/Mayor/Dashboard" style="color:var(--text-muted);text-decoration:none">Dashboard</a></li>
        <li class="breadcrumb-item"><a href="/Mayor/Mayor/Owners" style="color:var(--text-muted);text-decoration:none">Owners</a></li>
        <li class="breadcrumb-item active" style="color:var(--text-main)">@Model?.FullName</li>
    </ol>
</nav>

<div class="page-header">
    <h1>Owner Details</h1>
    <p>Viewing properties and heater usage for this owner.</p>
</div>

<div class="row g-3 mb-4">
    <!-- Profile Card -->
    <div class="col-12 col-lg-4">
        <div class="owner-profile-card">
            <div class="d-flex align-items-center gap-3 mb-4">
                <div class="owner-big-avatar">@initials</div>
                <div>
                    <div style="font-family:'Syne',sans-serif;font-weight:800;font-size:1.2rem">@Model?.FullName</div>
                    <div style="opacity:.6;font-size:.82rem">Property Owner</div>
                </div>
            </div>

            <div class="d-flex flex-column gap-3">
                <div>
                    <div class="owner-info-label">Phone Number</div>
                    <div class="owner-info-value">
                        <i class="bi bi-telephone me-2"></i>@Model?.PhoneNumber
                    </div>
                </div>
                <div>
                    <div class="owner-info-label">Total Properties</div>
                    <div class="owner-info-value">
                        <i class="bi bi-house me-2"></i>@Model?.houseCount houses
                    </div>
                </div>
            </div>

            <div class="mt-4 pt-3" style="border-top:1px solid rgba(255,255,255,.15)">
                <div class="d-flex gap-2 flex-wrap">
                    <span class="info-chip"><i class="bi bi-check-circle-fill"></i> Active Owner</span>
                    <span class="info-chip"><i class="bi bi-shield-fill-check"></i> Verified</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Summary Stats -->
    <div class="col-12 col-lg-8">
        <div class="row g-3 h-100">
            <div class="col-6">
                <div class="stat-card" style="height:100%">
                    <div class="stat-card-icon" style="background:rgba(0,201,167,.12);color:#00c9a7">
                        <i class="bi bi-house-fill"></i>
                    </div>
                    <div class="stat-card-label">Total Houses</div>
                    <div class="stat-card-value">@(Model?.houseCount ?? 0)</div>
                    <div class="stat-card-sub">Registered properties</div>
                </div>
            </div>
            <div class="col-6">
                <div class="stat-card" style="height:100%">
                    <div class="stat-card-icon" style="background:rgba(245,166,35,.12);color:#f5a623">
                        <i class="bi bi-lightning-charge-fill"></i>
                    </div>
                    <div class="stat-card-label">Total Heaters</div>
                    <div class="stat-card-value">@(ViewBag.TotalHeaters ?? 0)</div>
                    <div class="stat-card-sub">Across all properties</div>
                </div>
            </div>
            <div class="col-12">
                <div class="stat-card">
                    <div class="d-flex align-items-center justify-content-between">
                        <div>
                            <div class="stat-card-label">Today's Consumption</div>
                            <div class="stat-card-value" style="font-size:1.6rem">
                                @(((double)(ViewBag.TodayConsumption ?? 0.0)).ToString("N2"))
                                <span style="font-size:.9rem;font-weight:400;color:var(--text-muted)">kWh</span>
                            </div>
                        </div>
                        <div class="stat-card-icon" style="background:rgba(232,68,68,.12);color:#e84444;width:52px;height:52px;font-size:1.4rem">
                            <i class="bi bi-activity"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ── HOUSES TABLE ── -->
<div class="card">
    <div class="card-header-custom">
        <h2 class="card-title-custom"><i class="bi bi-houses me-2" style="color:#3b9eff"></i>Properties</h2>
        <span style="font-size:.78rem;color:var(--text-muted)">@(Model?.houseCount ?? 0) total</span>
    </div>
    <div class="table-responsive">
        <table class="table table-custom mb-0">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Address</th>
                    <th>City Zone</th>
                    <th>Heaters</th>
                    <th>Today's Usage</th>
                    <th style="text-align:right">Actions</th>
                </tr>
            </thead>
            <tbody>
                @{
                    int houseIdx = 1;
                    var houses = Model?.houses;
                }
                @if (houses != null && houses.Any())
                {
                    @foreach (var house in houses)
                    {
                        string zoneColor;
                        zoneColors.TryGetValue(house.CityZone ?? "", out zoneColor);
                        zoneColor ??= "#9b59b6";
                        int heaterCount = house.DailyUsages?.Count ?? 0;
                        <tr>
                            <td style="color:var(--text-muted);font-size:.8rem">@houseIdx</td>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <i class="bi bi-house" style="color:var(--text-muted)"></i>
                                    <strong>@house.Address</strong>
                                </div>
                            </td>
                            <td>
                                <span class="zone-badge" style="background:@(zoneColor)22;color:@zoneColor">
                                    @house.CityZone
                                </span>
                            </td>
                            <td>
                                <span style="font-weight:600">@heaterCount</span>
                                <span style="color:var(--text-muted);font-size:.8rem"> heaters</span>
                            </td>
                            <td>
                                <strong>
                                    @(house.DailyUsages?
                                        .Where(u => u.UsageDate.Date == DateTime.Today.Date)
                                        .Sum(u => u.HeaterValue) ?? 0)
                                </strong>
                                <span style="color:var(--text-muted);font-size:.8rem"> kWh</span>
                            </td>
                            <td style="text-align:right">
                                <a href="/Mayor/Mayor/HouseDetails/@house.OwnerId"
                                    class="btn-outline-primary-custom" style="font-size:.78rem;padding:6px 12px">
                                    <i class="bi bi-eye"></i> View Details
                                </a>
                            </td>
                        </tr>
                        houseIdx++;
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" style="text-align:center;padding:40px;color:var(--text-muted)">
                            <i class="bi bi-house" style="font-size:2rem;display:block;margin-bottom:8px"></i>
                            No houses registered for this owner.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Back Button -->
<div class="mt-3">
    <a href="/Mayor/Mayor/Owners" class="btn-outline-primary-custom">
        <i class="bi bi-arrow-left"></i> Back to Owners
    </a>
</div>
